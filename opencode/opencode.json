{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "websearch": "allow",
    "webfetch": "allow"
  },
  "default_agent": "local-team",
  "model": "ollama/local-gemma4-12b:latest",
  "small_model": "ollama/local-gemma4-12b:latest",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "local-gemma4-12b:latest": {
          "name": "Local Team - Gemma 4 12B 16K",
          "limit": {
            "context": 16384,
            "output": 8192
          }
        }
      }
    }
  }
}
